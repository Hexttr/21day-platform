# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/21day"

# JWT secret (generate a random string for production)
JWT_SECRET="your-secret-key-change-in-production"

# Google Gemini API (for AI chat, image, quiz)
GEMINI_API_KEY="your-gemini-api-key"

# Optional: chat model (default gemini-2.5-flash)
# GEMINI_CHAT_MODEL="gemini-2.5-flash"

# Optional: image model (default gemini-2.0-flash-preview-image-generation)
# GEMINI_IMAGE_MODEL="gemini-2.0-flash-preview-image-generation"

# Server port (default 3001)
# PORT=3001
